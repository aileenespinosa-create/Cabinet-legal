{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.cabinetlegal.com.do"
        }
      ],
      "destination": "https://cabinetlegal.com.do/:path*",
      "permanent": true
    }
  ]
}
